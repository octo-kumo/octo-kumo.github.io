{"_path":"/ctf/2024-ictf/crypto/integrity","_dir":"crypto","_draft":false,"_partial":false,"_locale":"","title":"","description":"We can observe that the same flag is encrypted twice using RSA, with the same modulus n and two different e.","created":"2024-07-19T22:35","updated":"2024-08-05T19:43","tags":["rsa","modulus"],"solves":172,"points":100,"readingTime":{"text":"1 min read","minutes":0.845,"time":50700,"words":169},"body":{"type":"root","children":[{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"We can observe that the same "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"flag"}]},{"type":"text","value":" is encrypted twice using RSA, with the same modulus "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"n"}]},{"type":"text","value":" and two different "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"e"}]},{"type":"text","value":"."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"This means we can employ "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Common Modulus Attack"}]},{"type":"text","value":"."}]},{"type":"element","tag":"blockquote","props":{},"children":[{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"If a single plaintext has been encrypted to two ciphertexts by keys with the same modulus but different exponent, this plaintext can be recovered if "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"gcd(e1, e2) = 1"}]},{"type":"text","value":" and "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"gcd(ct2, n) = 1"}]},{"type":"text","value":"."}]}]},{"type":"element","tag":"pre","props":{"className":"language-python shiki shiki-themes one-light one-dark-pro monokai","code":"from pqdm.threads import pqdm\nfrom math import gcd\nimport string\nfrom Crypto.Util.number import long_to_bytes\n\nn = \nct = \nsignature = \n\n# referenced https://github.com/maximmasiutin/rsa-common-modulus/blob/main/rsa-common-modulus.py\n\n\ndef modinv(a, m):\n    return pow(a, -1, m)\n\n\ndef attack(c1, c2, e1, e2, N):\n    g = gcd(e1, e2)\n    s1 = modinv(e1, e2)\n    s2 = (g - e1 * s1) // e2\n    temp = modinv(c2, N)\n    m1 = pow(c1, s1, N)\n    m2 = pow(temp, -s2, N)\n    r1 = (m1 * m2) % N\n    return r1\n\n\ndef process(e2):\n    M_recovered = long_to_bytes(attack(ct, signature, 65537, e2, n))\n    if all([c in string.printable.encode() for c in M_recovered]):\n        print(\"found!!\")\n        print(M_recovered)\n        exit()\n    return 0\n\n# loop through every possible value of the 16 bit crc\nresult = pqdm(range(1, 65536), process, n_jobs=16)\n","language":"python","meta":"","style":""},"children":[{"type":"element","tag":"code","props":{"__ignoreMap":""},"children":[{"type":"element","tag":"span","props":{"class":"line","line":1},"children":[{"type":"element","tag":"span","props":{"style":"--shiki-default:#A626A4;--shiki-dark:#C678DD;--shiki-sepia:#F92672"},"children":[{"type":"text","value":"from"}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#383A42;--shiki-dark:#ABB2BF;--shiki-sepia:#F8F8F2"},"children":[{"type":"text","value":" pqdm.threads "}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#A626A4;--shiki-dark:#C678DD;--shiki-sepia:#F92672"},"children":[{"type":"text","value":"import"}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#383A42;--shiki-dark:#ABB2BF;--shiki-sepia:#F8F8F2"},"children":[{"type":"text","value":" pqdm\n"}]}]},{"type":"element","tag":"span","props":{"class":"line","line":2},"children":[{"type":"element","tag":"span","props":{"style":"--shiki-default:#A626A4;--shiki-dark:#C678DD;--shiki-sepia:#F92672"},"children":[{"type":"text","value":"from"}]},{"type":"element","tag":"span","props":{"style":"--shiki-default:#383A42;--shiki-dark:#ABB2BF;--shiki-sepia:#F8F8F2"},"c